<% content_for :title, "Admin · Edit #{@mission.name}" %>

<div class="app-layout app-layout--wide">
  <div class="app-layout__main app-layout__main--wide">
    <article class="admin-mission">
      <p class="admin-mission__breadcrumb">
        <%= link_to "← #{@mission.name}", admin_mission_path(@mission.slug), class: "admin-mission__breadcrumb-link" %>
      </p>

      <header class="admin-mission__page-header">
        <h1 class="admin-mission__page-title">Edit <%= @mission.name %></h1>
      </header>

      <section class="admin-mission__section">
        <h2 class="admin-mission__section-title">Mission settings</h2>
        <p class="admin-mission__hint">
          The admin page only edits the slug. Everything else (title, description,
          guide, prizes, memberships, shop unlocks, default project copy, etc.) lives
          on the manage page — admins have access there too.
        </p>
        <div class="admin-mission__actions">
          <%= link_to "Manage this mission →",
                      edit_manage_mission_path(@mission.slug),
                      class: "action-btn action-btn--large action-btn--primary" %>
        </div>
      </section>

      <section class="admin-mission__section">
        <h2 class="admin-mission__section-title">Slug</h2>
        <p class="admin-mission__hint">
          Renaming the slug changes the public URL. Existing links to
          <code class="admin-mission__code">/missions/<%= @mission.slug %></code>
          will 404 after this change.
        </p>
        <%= form_with model: @mission, url: admin_mission_path(@mission.slug), method: :patch,
              local: true, class: "admin-mission__form" do |f| %>
          <% if @mission.errors.any? %>
            <div class="admin-mission__errors">
              <ul>
                <% @mission.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          <label class="admin-mission__field">
            <span class="admin-mission__field-label">Slug</span>
            <%= f.text_field :slug, required: true %>
          </label>
          <%= f.submit "Update slug", class: "action-btn action-btn--small action-btn--primary" %>
        <% end %>
      </section>

      <section class="admin-mission__section">
        <h2 class="admin-mission__section-title">Owners</h2>
        <p class="admin-mission__hint">
          Owners can manage the mission via the manage page (edit content,
          add reviewers, configure prizes, etc.). Only admins can grant or
          revoke ownership.
        </p>
        <% if @owners.any? %>
          <ul class="admin-mission__list">
            <% @owners.each do |m| %>
              <li>
                <span><%= m.user.display_name %> <span class="admin-mission__muted">(#<%= m.user.id %>)</span></span>
                <%= button_to "Remove",
                              admin_mission_membership_path(@mission.slug, m),
                              method: :delete,
                              data: { turbo_confirm: "Remove #{m.user.display_name} as an owner?" },
                              class: "action-btn action-btn--small action-btn--destructive" %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="admin-mission__empty">No owners yet. Add one so this mission can be managed without admin.</p>
        <% end %>
        <%= form_with url: admin_mission_memberships_path(@mission.slug), method: :post, local: true, class: "admin-mission__form" do %>
          <label class="admin-mission__field">
            <span class="admin-mission__field-label">User ID or Slack ID</span>
            <%= text_field_tag "mission_membership[user_id]", nil, required: true, autocomplete: "off" %>
          </label>
          <%= submit_tag "Add owner", class: "action-btn action-btn--small action-btn--primary" %>
        <% end %>
      </section>

      <section class="admin-mission__section">
        <h2 class="admin-mission__section-title">Danger zone</h2>
        <% if @mission.deleted_at? %>
          <p class="admin-mission__hint">
            This mission is soft-deleted (since <%= @mission.deleted_at.to_date %>).
            Restore to make it visible again.
          </p>
          <%= button_to "Restore mission",
                        restore_admin_mission_path(@mission.slug),
                        method: :post,
                        class: "action-btn action-btn--small action-btn--primary" %>
        <% else %>
          <p class="admin-mission__hint">
            Soft-deletes the mission. It disappears from the public listing
            and project picker but stays in the database, so this can be
            undone with Restore.
          </p>
          <%= button_to "Soft-delete mission",
                        admin_mission_path(@mission.slug),
                        method: :delete,
                        data: { turbo_confirm: "Soft-delete #{@mission.name}?" },
                        class: "action-btn action-btn--small action-btn--destructive" %>
        <% end %>
      </section>
    </article>
  </div>
</div>
